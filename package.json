{
  "name": "mason-navigator-kiosk",
  "version": "1.0.0",
  "description": "Mason High School Kiosk Navigator",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win --x64",
    "build-linux": "electron-builder --linux --x64"
  },
  "build": {
    "appId": "com.masonschools.navigator",
    "productName": "Mason Navigator",
    "directories": { "output": "dist" },
    "files": ["src/**/*", "assets/**/*", "data/**/*"],
    "extraResources": [
      { "from": "assets/", "to": "assets/", "filter": ["**/*"] },
      { "from": "data/",   "to": "data/",   "filter": ["**/*"] }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "category": "Education"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
